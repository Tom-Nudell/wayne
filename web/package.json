{
  "name": "@wayne/web",
  "version": "0.0.0",
  "private": true,
  "description": "Wayne — commercial US energy infrastructure map. SvelteKit on Vercel.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "size": "size-limit",
    "link-tiles": "bash scripts/link-tiles.sh"
  },
  "size-limit": [
    {
      "name": "entry + shared chunks (gzipped)",
      "path": ".svelte-kit/output/client/_app/immutable/entry/*.js",
      "limit": "250 KB"
    }
  ],
  "dependencies": {
    "@wayne/api": "workspace:*",
    "@wayne/map": "workspace:*",
    "@wayne/schema": "workspace:*",
    "@wayne/ui": "workspace:*",
    "maplibre-gl": "^4.7.0",
    "pmtiles": "^3.2.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^5.5.0",
    "@types/node": "^20.16.0",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@size-limit/preset-app": "^11.0.0",
    "size-limit": "^11.0.0",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
